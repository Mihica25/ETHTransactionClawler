ETHERSCAN_API_KEY=your_api_key_here
CHAIN_ID=1
PORT=3000

# Database Configuration
# Option 1 (Recommended): Use your system username with peer authentication (Linux/macOS)
# Run 'whoami' to see your username, then uncomment and update:
# DB_USER=your_username
# DB_PASSWORD=

# Option 2: Use postgres superuser with password
# DB_USER=postgres
# DB_PASSWORD=your_password_here

# Default values (change based on option above)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eth_transactions
DB_USER=postgres
DB_PASSWORD=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
FETCH_TIMEOUT_MS=15000
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_key_here
