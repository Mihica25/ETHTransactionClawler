{
  "name": "eth-transactions-crawler",
  "version": "1.0.0",
  "description": "Ethereum transactions crawler using Etherscan API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run build && npm start\"",
    "clean": "rm -rf dist",
    "db:setup": "bash scripts/setup-db.sh"
  },
  "keywords": [
    "ethereum",
    "blockchain",
    "transactions"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.18.0"
  }
}
